{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "format": "page",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "single": "heading1"
        }
      },
      "publication_date": {
        "type": "Date",
        "config": {
          "label": "Publication Date"
        }
      },
      "cover_image": {
        "type": "Image",
        "config": {
          "label": "Cover Image"
        }
      },
      "excerpt": {
        "type": "Text",
        "config": {
          "label": "Excerpt",
          "placeholder": "Short summary of the post"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "multi": "heading2,heading3,paragraph,strong,em,hyperlink,list-item,o-list-item,image,preformatted"
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "fields": {
            "tag": {
              "type": "Text",
              "config": {
                "label": "Tag"
              }
            }
          }
        }
      },
      "related_case_studies": {
        "type": "Group",
        "config": {
          "label": "Related Case Studies",
          "fields": {
            "case_study": {
              "type": "Link",
              "config": {
                "label": "Case Study",
                "select": "document",
                "customtypes": [
                  {
                    "id": "case_study",
                    "fields": [
                      "dog_name",
                      "location"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      }
    }
  }
}